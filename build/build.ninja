  DEP_FILE = tests/CMakeFiles/unit_tests.dir/link.d
  FLAGS = -O3 -DNDEBUG
  LINK_FLAGS = -Wl,--dependency-file=tests/CMakeFiles/unit_tests.dir/link.d
  LINK_LIBRARIES = lib/libgtest_main.a  src/core/engine/libtrading_engine.a  src/core/strategy/libstrategies.a  src/ml/inference/libinference_engine.a  src/storage/libstorage.a  src/logging/liblogging.a  src/cli/libcli.a  lib/libgtest.a  src/core/engine/libtrading_engine.a  src/core/strategy/libstrategies.a  src/ml/inference/libinference_engine.a  src/storage/libstorage.a  src/logging/liblogging.a  _deps/spdlog-build/libspdlog.a
  OBJECT_DIR = tests/CMakeFiles/unit_tests.dir
  POST_BUILD = cd /tmp/workspace/somat3k/Daydream_handler/build/tests && /usr/local/bin/cmake -D TEST_TARGET=unit_tests -D TEST_EXECUTABLE=/tmp/workspace/somat3k/Daydream_handler/build/tests/unit_tests -D TEST_EXECUTOR= -D TEST_WORKING_DIR=/tmp/workspace/somat3k/Daydream_handler/build/tests -D TEST_EXTRA_ARGS= -D TEST_PROPERTIES= -D TEST_PREFIX= -D TEST_SUFFIX= -D TEST_FILTER= -D NO_PRETTY_TYPES=FALSE -D NO_PRETTY_VALUES=FALSE -D TEST_LIST=unit_tests_TESTS -D CTEST_FILE=/tmp/workspace/somat3k/Daydream_handler/build/tests/unit_tests[1]_tests.cmake -D TEST_DISCOVERY_TIMEOUT=5 -D TEST_DISCOVERY_EXTRA_ARGS= -D TEST_XML_OUTPUT_DIR= -P /usr/local/share/cmake-3.31/Modules/GoogleTestAddTests.cmake
  PRE_LINK = :
  RESTAT = 1
  TARGET_COMPILE_PDB = tests/CMakeFiles/unit_tests.dir/
  TARGET_FILE = tests/unit_tests
  TARGET_PDB = tests/unit_tests.pdb


